# ─── Runtime ───────────────────────────────────────────────────────
NODE_ENV=development
PORT=5002
TRUST_PROXY=false

# ─── Database (never commit real URI) ──────────────────────────────
MONGO_URI=mongodb://127.0.0.1:27017/zashly

# ─── Auth secrets (generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))") ───
JWT_SECRET=change_me_to_at_least_32_random_characters_long
JWT_REFRESH_SECRET=change_me_another_distinct_32_char_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── CORS (production) ─────────────────────────────────────────────
CLIENT_URL=http://localhost:5173
CLIENT_URLS=https://yourdomain.com,https://www.yourdomain.com

# ─── Account security ──────────────────────────────────────────────
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=15
ENABLE_EMAIL_VERIFICATION=false

# ─── Stream Chat / Video ───────────────────────────────────────────
STREAM_API_KEY=
STREAM_API_SECRET=

# ─── LiveKit (Voice & Video Calls) ───────────────────────────────
# Get credentials from https://cloud.livekit.io
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=wss://your-project.livekit.cloud
