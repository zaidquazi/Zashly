# Backend Configuration
PORT=3001  # Port for the backend server
NODE_ENV=development  # Set to 'production' in production

# MongoDB Configuration
MONGODB_URI=your_mongodb_connection_string  # MongoDB connection string

# JWT Configuration
JWT_SECRET=your_jwt_secret_key  # Secret key for JWT token signing
JWT_EXPIRES_IN=7d  # JWT token expiration time

# Stream Chat Configuration
STREAM_API_KEY=your_stream_chat_api_key  # Stream Chat API key
STREAM_API_SECRET=your_stream_chat_api_secret  # Stream Chat API secret

# Frontend Configuration (for development)
VITE_API_URL=http://localhost:3001  # Backend API URL for frontend
VITE_STREAM_CHAT_API_KEY=your_stream_chat_api_key  # Same as STREAM_API_KEY

# CORS Configuration (for development)
FRONTEND_ORIGIN=http://localhost:5173  # Frontend development server URL

# Admin Configuration
ADMIN_EMAIL=admin@zashly.com  # Default admin email
ADMIN_PASSWORD=admin123456  # Default admin password
